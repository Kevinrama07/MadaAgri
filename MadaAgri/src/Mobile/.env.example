# Configuration Expo - Variables d'environnement
# Format: EXPO_PUBLIC_* sont accessibles dans Constants.expoConfig.extra
# NE PAS INCLURE /api - c'est ajouté automatiquement par le code

# 🔧 URLs API - IMPORTANT: juste l'URL de base sans /api
# Exemples:
#   - http://192.168.1.100:4000     (IP locale - recommandé)
#   - http://localhost:4000          (développement local)
#   - https://api.madaagri.com:4000  (production)

EXPO_PUBLIC_API_URL=http://192.168.88.23:4000
EXPO_PUBLIC_SOCKET_URL=http://192.168.88.23:4000
EXPO_PUBLIC_ANDROID_EMULATOR_IP=10.0.2.2:4000

# 🔧 Configuration de l'app
EXPO_PUBLIC_APP_NAME=MadaAgri
EXPO_PUBLIC_VERSION=1.0.0

# 🔧 Features
EXPO_PUBLIC_ENABLE_ANALYTICS=false
EXPO_PUBLIC_ENABLE_NOTIFICATIONS=false
EXPO_PUBLIC_ENABLE_OFFLINE_MODE=true

# 🔧 Debug
EXPO_PUBLIC_DEBUG_ENABLED=true

# ⚙️ Notes:
# - Changer EXPO_PUBLIC_API_URL pour votre IP locale
# - Relancer Expo après chaque modification: npm start
# - Voir IP_CONFIGURATION_GUIDE.md pour plus de détails
