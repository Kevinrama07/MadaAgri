# ============================================
# MADAAGRI BACKEND - ENVIRONMENT VARIABLES
# ============================================
# Copier ce fichier vers `.env` et remplir les valeurs réelles
# NE JAMAIS commiter le fichier .env dans Git!

# ============================================
# ENVIRONNEMENT
# ============================================
NODE_ENV=development
# Valeurs possibles: development, staging, production

# ============================================
# SERVEUR
# ============================================
PORT=4000
HOST=0.0.0.0
# En production, utiliser 0.0.0.0 pour écouter sur toutes les interfaces

# ============================================
# BASE DE DONNÉES MYSQL
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=madaagri_user
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DB_NAME=madaagri
DB_CONNECTION_LIMIT=10
# En production, utiliser un mot de passe fort (min 16 caractères)

# ============================================
# REDIS (Cache & Sessions)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Laisser vide si pas de mot de passe Redis

# ============================================
# AUTHENTIFICATION JWT
# ============================================
JWT_SECRET=CHANGE_THIS_TO_RANDOM_STRING_MIN_32_CHARS
JWT_EXPIRES_IN=7d
# IMPORTANT: Générer un secret fort avec: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ============================================
# CLOUDINARY (Upload d'images)
# ============================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Obtenir les clés sur: https://cloudinary.com/console

# ============================================
# CORS (Cross-Origin Resource Sharing)
# ============================================
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
# En production: https://madaagri.mg,https://www.madaagri.mg
# Séparer plusieurs origines par des virgules

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
# 15 minutes en millisecondes
RATE_LIMIT_MAX_REQUESTS=100
# Nombre max de requêtes par fenêtre

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
# Valeurs: error, warn, info, http, verbose, debug, silly
LOG_FILE_PATH=./logs
# Chemin vers le dossier des logs

# ============================================
# EMAIL (Optionnel - pour notifications)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@madaagri.mg
# Pour Gmail, utiliser un App Password

# ============================================
# MOBILE MONEY (Optionnel - pour paiements)
# ============================================
ORANGE_MONEY_API_KEY=
ORANGE_MONEY_API_SECRET=
MVOLA_API_KEY=
MVOLA_API_SECRET=

# ============================================
# MONITORING (Optionnel)
# ============================================
SENTRY_DSN=
# URL Sentry pour tracking des erreurs

# ============================================
# NOTES DE SÉCURITÉ PRODUCTION
# ============================================
# 1. Changer TOUS les secrets et mots de passe
# 2. Utiliser des mots de passe forts (min 16 caractères)
# 3. Activer HTTPS uniquement
# 4. Définir CORS_ORIGIN avec domaines spécifiques
# 5. Activer le firewall
# 6. Configurer les backups automatiques
# 7. Mettre en place le monitoring
# 8. Limiter les connexions DB
# 9. Utiliser des variables d'environnement système
# 10. Ne JAMAIS exposer ce fichier publiquement
